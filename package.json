{
  "name": "atlas-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Atlas Employee Portal — backend services",
  "scripts": {
    "dev": "cd services/api && npx tsx watch src/index.ts",
    "build": "rm -rf dist && npx prisma generate && npx tsc",
    "start": "npx prisma db push --accept-data-loss && node dist/services/api/src/index.js",
    "seed:demo": "npx ts-node scripts/seed-demo.ts",
    "seed:anil": "npx tsx scripts/seed-anil.ts",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio",
    "db:seed": "npx prisma db seed",
    "db:backup": "./scripts/backup-db.sh",
    "db:backup:r2": "npx tsx scripts/backup-to-r2.ts",
    "smoke": "npx tsx services/api/src/scripts/smoke-test.ts",
    "db:encrypt-xoauth": "npx tsx services/api/src/scripts/encrypt-xoauth-tokens.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-s3": "^3.1023.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.5.0",
    "@sentry/node": "^10.47.0",
    "@supabase/supabase-js": "^2.49.1",
    "@types/multer": "^2.1.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.6.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "openai": "^6.33.0",
    "pdf-parse": "^1.1.1",
    "pino": "^10.3.1",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "telegraf": "^4.16.3",
    "yamljs": "^0.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.10",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.3.0",
    "prisma": "^6.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  }
}
