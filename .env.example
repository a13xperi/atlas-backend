# Database (Railway auto-provides)
DATABASE_URL=postgresql://user:password@localhost:5432/atlas

# Redis (Railway auto-provides)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-jwt-secret-here

# Supabase Auth (optional — falls back to bcrypt+JWT if not set)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Frontend
FRONTEND_URL=http://localhost:3000

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-here

# AI Services
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# Cloudflare R2 Backups (for db:backup:r2 script)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=atlas-backups
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key

# Server
PORT=8000
