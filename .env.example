# Server / frontend
PORT=8000
FRONTEND_URL=https://delphi-atlas.vercel.app,https://atlas-staging.vercel.app,http://localhost:3000
# Railway request timeout in ms. Anthropic-backed generation/calibration routes need 90s.
RAILWAY_SERVICE_TIMEOUT=90000

# Database (Railway auto-provides in deployed environments)
DATABASE_URL=postgresql://user:password@localhost:5432/atlas

# Redis (Railway auto-provides in deployed environments)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-jwt-secret-here

# Supabase Auth (optional — falls back to bcrypt+JWT if not set)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# AI providers
# OpenAI API key for generation and research features
OPENAI_API_KEY=your-openai-key-here
# Anthropic API key for Claude-powered generation and research features
ANTHROPIC_API_KEY=your-anthropic-key-here
# Google AI / Gemini API key for image generation and Gemini-backed workflows
GOOGLE_AI_API_KEY=your-google-ai-api-key-here
# Gemini model override used by the Google AI client (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
# Optional dedicated Gemini image model override for /api/images (default fallback: gemini-2.5-flash-image)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# xAI / Grok API key for trending and research features
XAI_API_KEY=your-xai-api-key-here

# X / Twitter integration
# Bearer token for read-only X API access
TWITTER_BEARER_TOKEN=your-twitter-bearer-token-here
# OAuth 2.0 client ID for X account linking and posting flows
TWITTER_CLIENT_ID=your-twitter-client-id-here
# OAuth 2.0 client secret for X account linking and posting flows
TWITTER_CLIENT_SECRET=your-twitter-client-secret-here
# OAuth callback URL for account linking flow
TWITTER_OAUTH_CALLBACK_URL=http://localhost:8000/api/auth/x/callback
# OAuth callback URL for Twitter login flow (must have trailing slash — X requires it)
TWITTER_LOGIN_CALLBACK_URL=http://localhost:8000/api/auth/twitter/callback/

# Monitoring
# Optional Sentry DSN for backend error tracking
SENTRY_DSN=your-sentry-dsn-here

# QA / capacity Supabase
# Separate Supabase project URL used by QA and capacity routes
QA_SUPABASE_URL=https://your-qa-project.supabase.co
# Separate Supabase anon key used by QA and capacity routes
QA_SUPABASE_KEY=your-qa-project-anon-key

# GitHub / AutoResearch loop features
# GitHub API token used for loop-driven PR creation
GITHUB_TOKEN=your-github-token-here
# GitHub repo owner used by loop routes (default: a13xperi)
GITHUB_OWNER=a13xperi
# GitHub repo name used by loop routes (default: atlas-portal)
GITHUB_REPO=atlas-portal
# Filesystem path for persisted Ralph loop state (default: .ralph/state.json)
RALPH_STATE_PATH=.ralph/state.json

# Telegram
# API service bot token for alerts and notifications
TELEGRAM_BOT_TOKEN=your-bot-token-here
# telegram-bot service token (separate service)
BOT_TOKEN=your-telegram-bot-token-here

# Paperclip integration
# API key Atlas uses to create Paperclip tasks
PAPERCLIP_API_KEY=your-paperclip-api-key-here
# Shared secret expected in the x-paperclip-secret webhook header
PAPERCLIP_WEBHOOK_SECRET=your-paperclip-webhook-secret-here

# Cloudflare R2 backups (db:backup:r2 script)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=atlas-backups
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
# Optional backup retention window in days (default: 30)
BACKUP_RETENTION_DAYS=30
# Optional local backup output directory (used by backup service)
BACKUP_LOCAL_DIR=backups

# Supabase Management API (optional — enables restore-point snapshots when available)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_MANAGEMENT_API_TOKEN=your-supabase-management-token

# Seed scripts — set per-environment, never commit real values
SEED_PASSWORD=change-me-min-12-chars
DEMO_SEED_PASSWORD=change-me-min-12-chars
ALEX_SEED_PASSWORD=change-me-min-12-chars
ANIL_SEED_PASSWORD=change-me-min-12-chars
