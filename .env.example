# Database (Railway auto-provides)
DATABASE_URL=postgresql://user:password@localhost:5432/atlas

# Redis (Railway auto-provides)
REDIS_URL=redis://localhost:6379

# Rate limiting
# Auth endpoints under /api/auth/* — requests per IP
RATE_LIMIT_AUTH_MAX_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW_MS=60000
# AI generation endpoints — requests per authenticated user
RATE_LIMIT_AI_GENERATION_MAX_REQUESTS=20
RATE_LIMIT_AI_GENERATION_WINDOW_MS=3600000
# General API traffic — requests per authenticated user
RATE_LIMIT_GENERAL_MAX_REQUESTS=100
RATE_LIMIT_GENERAL_WINDOW_MS=60000

# Auth
JWT_SECRET=your-jwt-secret-here

# Supabase Auth (optional — falls back to bcrypt+JWT if not set)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Frontend
FRONTEND_URL=http://localhost:3000

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-here
# API key Atlas uses to create Paperclip tasks
PAPERCLIP_API_KEY=your-paperclip-api-key-here
# Shared secret expected in the x-paperclip-secret webhook header
PAPERCLIP_WEBHOOK_SECRET=your-paperclip-webhook-secret-here

# AI Services
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# Cloudflare R2 Backups (used by the API backup service and db:backup:r2 script)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=atlas-backups
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
BACKUP_RETENTION_DAYS=30
BACKUP_LOCAL_DIR=backups

# Supabase Management API (optional — enables restore-point snapshots when available)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_MANAGEMENT_API_TOKEN=your-supabase-management-token

# Server
PORT=8000
