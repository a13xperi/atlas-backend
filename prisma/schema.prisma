generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  supabaseId    String?
  handle        String   @unique
  email         String?  @unique
  passwordHash  String?
  displayName   String?
  avatarUrl     String?
  role          Role     @default(ANALYST)
  onboardingTrack OnboardingTrack?
  telegramChatId    String?
  xHandle           String?
  xAccessToken      String?
  xRefreshToken     String?
  xTokenExpiresAt   DateTime?
  tourCompleted     Boolean  @default(false)
  tourStep          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  voiceProfile      VoiceProfile?
  referenceVoices   ReferenceVoice[]
  savedBlends       SavedBlend[]
  tweetDrafts       TweetDraft[]
  analyticsEvents   AnalyticsEvent[]
  alertSubscriptions AlertSubscription[]
  sessions          Session[]
  researchResults   ResearchResult[]
  generatedImages   GeneratedImage[]
  alerts            Alert[]
  briefingPreference BriefingPreference?
  briefings          Briefing[]
  nlpMonitors       NlpMonitor[]
  campaigns         Campaign[]
  voiceDimensionInsight VoiceDimensionInsight?
  blendedVoiceProfile   BlendedVoiceProfile?

  @@map("users")
}

enum Role {
  ANALYST
  MANAGER
  ADMIN
}

enum OnboardingTrack {
  TRACK_A
  TRACK_B
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VoiceProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  humor           Int      @default(50)
  formality       Int      @default(50)
  brevity         Int      @default(50)
  contrarianTone  Int      @default(50)
  directness               Int     @default(50)
  warmth                   Int     @default(50)
  technicalDepth           Int     @default(50)
  confidence               Int     @default(50)
  evidenceOrientation      Int     @default(50)
  solutionOrientation      Int     @default(50)
  socialPosture            Int     @default(50)
  selfPromotionalIntensity Int     @default(50)
  maturity        VoiceMaturity @default(BEGINNER)
  tweetsAnalyzed  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("voice_profiles")
}

enum VoiceMaturity {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model ReferenceVoice {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  handle      String?
  avatarUrl   String?
  category    String?
  isActive    Boolean  @default(true)
  isGlobal    Boolean  @default(false)
  createdAt   DateTime @default(now())

  user         User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  blendVoices  BlendVoice[]
  voiceProfile ReferenceVoiceProfile?

  @@map("reference_voices")
}

model ReferenceVoiceProfile {
  id                       String   @id @default(cuid())
  referenceVoiceId         String   @unique

  // Voice dimensions (0-100)
  humor                    Int      @default(50)
  formality                Int      @default(50)
  brevity                  Int      @default(50)
  contrarianTone           Int      @default(50)
  directness               Int      @default(50)
  warmth                   Int      @default(50)
  technicalDepth           Int      @default(50)
  confidence               Int      @default(50)
  evidenceOrientation      Int      @default(50)
  solutionOrientation      Int      @default(50)
  socialPosture            Int      @default(50)
  selfPromotionalIntensity Int      @default(50)

  // Calibration metadata
  calibrationConfidence    Float?
  analysis                 String?
  tweetsAnalyzed           Int      @default(0)
  sampleTweets             String[]
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  referenceVoice ReferenceVoice @relation(fields: [referenceVoiceId], references: [id], onDelete: Cascade)

  @@map("reference_voice_profiles")
}

model SavedBlend {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  voices BlendVoice[]

  @@map("saved_blends")
}

model BlendVoice {
  id              String @id @default(cuid())
  blendId         String
  referenceVoiceId String?
  label           String
  percentage      Int

  blend          SavedBlend      @relation(fields: [blendId], references: [id], onDelete: Cascade)
  referenceVoice ReferenceVoice? @relation(fields: [referenceVoiceId], references: [id], onDelete: SetNull)

  @@map("blend_voices")
}

model TweetDraft {
  id            String      @id @default(cuid())
  userId        String
  content       String
  version       Int         @default(1)
  status        DraftStatus @default(DRAFT)
  confidence    Float?
  predictedEngagement Int?
  actualEngagement    Int?
  engagementMetrics   Json?
  xTweetId      String?
  metricsLastFetchedAt DateTime?
  sourceType    SourceType?
  sourceContent String?
  blendId       String?
  feedback      String?
  scheduledAt   DateTime?
  campaignId    String?
  sortOrder     Int?
  voiceDimensionsSnapshot Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  images   GeneratedImage[]
  campaign Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([status, scheduledAt])
  @@index([campaignId])
  @@index([userId, sortOrder])
  @@map("tweet_drafts")
}

enum DraftStatus {
  DRAFT
  APPROVED
  SCHEDULED
  POSTED
  ARCHIVED
}

enum SourceType {
  REPORT
  ARTICLE
  TWEET
  TRENDING_TOPIC
  VOICE_NOTE
  MANUAL
}

model AnalyticsEvent {
  id        String        @id @default(cuid())
  userId    String
  type      AnalyticsType
  value     Float?
  metadata  Json?
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
  @@map("analytics_events")
}

enum AnalyticsType {
  DRAFT_CREATED
  DRAFT_POSTED
  FEEDBACK_GIVEN
  VOICE_REFINEMENT
  REPORT_INGESTED
  ENGAGEMENT_RECORDED
  SESSION_START
  RESEARCH_CONDUCTED
  ALERT_GENERATED
  IMAGE_GENERATED
}

model AlertSubscription {
  id        String    @id @default(cuid())
  userId    String
  type      AlertType
  value     String
  isActive  Boolean   @default(true)
  delivery  AlertDelivery[] @default([PORTAL])
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, value])
  @@map("alert_subscriptions")
}

enum AlertType {
  CATEGORY
  ACCOUNT
  REPORT_TYPE
}

enum AlertDelivery {
  PORTAL
  TELEGRAM
}

enum AlertCategory {
  SIGNAL
  NOTIFICATION
}

model Alert {
  id          String      @id @default(cuid())
  type        String
  title       String
  context     String?
  draftReply  String?
  sourceUrl   String?
  sentiment   String?
  relevance   Float?
  category    AlertCategory @default(SIGNAL)
  userId      String?
  expiresAt   DateTime?
  deliveredAt DateTime?
  createdAt   DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("alerts")
}

model LearningLogEntry {
  id        String   @id @default(cuid())
  userId    String
  event     String
  impact    String
  positive  Boolean
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("learning_log")
}

model ResearchResult {
  id              String   @id @default(cuid())
  userId          String
  query           String
  summary         String
  keyFacts        Json
  sentiment       String
  relatedTopics   Json
  sources         Json
  confidence      Float
  draftId         String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("research_results")
}

model BriefingPreference {
  id           String   @id @default(cuid())
  userId       String   @unique
  deliveryTime String   @default("08:00")
  topics       String[]
  sources      String[]
  channel      String   @default("PORTAL")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt    DateTime @updatedAt

  @@map("briefing_preferences")
}

model Briefing {
  id        String   @id @default(cuid())
  userId    String
  title     String
  summary   String
  sections  Json
  topics    String[]
  sources   String[]
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("briefings")
}

model GeneratedImage {
  id          String   @id @default(cuid())
  userId      String
  draftId     String?
  prompt      String
  style       String
  imageUrl    String
  mimeType    String   @default("image/png")
  createdAt   DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  draft TweetDraft? @relation(fields: [draftId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("generated_images")
}

model NlpMonitor {
  id           String          @id @default(cuid())
  userId       String
  name         String
  keywords     String[]
  minRelevance Float           @default(0.5)
  delivery     AlertDelivery[] @default([PORTAL])
  isActive     Boolean         @default(true)
  matchCount   Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, isActive])
  @@map("nlp_monitors")
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  COMPLETED
  PAUSED
}

model Campaign {
  id          String         @id @default(cuid())
  userId      String
  name        String
  description String?
  status      CampaignStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  drafts TweetDraft[]

  @@index([userId, status])
  @@map("campaigns")
}

model VoiceDimensionInsight {
  id                  String   @id @default(cuid())
  userId              String   @unique
  sampleSize          Int      @default(0)
  avgPerformanceScore Float?
  dimensionScores     Json?
  topCombinations     Json?
  recommendations     Json?
  computedAt          DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("voice_dimension_insights")
}

model BlendedVoiceProfile {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  primaryTwitterId         String
  primaryHandle            String?
  additionalTwitterIds     String[]
  additionalHandles        String[]
  weights                  Json     // { "twitter_id": weight_value }

  // Blended style dimensions (0-100)
  humor                    Int      @default(50)
  formality                Int      @default(50)
  brevity                  Int      @default(50)
  contrarianTone           Int      @default(50)
  directness               Int      @default(50)
  warmth                   Int      @default(50)
  technicalDepth           Int      @default(50)
  confidence               Int      @default(50)
  evidenceOrientation      Int      @default(50)
  solutionOrientation      Int      @default(50)
  socialPosture            Int      @default(50)
  selfPromotionalIntensity Int      @default(50)

  // Raw style signals per inspiration (for transparency / debugging)
  styleSignals             Json?    // { "twitter_id": { avgLength, emojiRate, ... } }

  // Meta
  tweetsAnalyzed           Int      @default(0)
  blendSummary             String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("blended_voice_profiles")
}

model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(true)
  rolloutRole String   @default("everyone")
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}

enum BackupStatus {
  PENDING
  SUCCESS
  FAILED
}

enum BackupTriggerSource {
  MANUAL
  SCHEDULED
}

enum BackupProvider {
  SUPABASE_RESTORE_POINT
  R2_LOGICAL
  LOCAL_LOGICAL
}

model BackupLog {
  id            String              @id @default(cuid())
  triggeredAt   DateTime            @default(now())
  status        BackupStatus        @default(PENDING)
  triggerSource BackupTriggerSource
  provider      BackupProvider?
  size          Int?
  storageUrl    String?
  errorMessage  String?
  completedAt   DateTime?

  @@index([triggeredAt])
  @@index([triggerSource, triggeredAt])
  @@map("backup_logs")
}
